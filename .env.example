# =============================================================================
# Veritas AI — Live News API Configuration
# =============================================================================
# 1. Copy this file:  copy .env.example .env
# 2. Add your keys below (get free keys from the links)
# 3. Or run:  python setup_api_keys.py
#
# NEVER commit .env to git — it contains secrets.
# =============================================================================

# GNews (recommended — https://gnews.io/)
GNEWS_API_KEY=

# NewsAPI (https://newsapi.org/)
NEWS_API_KEY=

# Optional: enable debug logs for live search
# VERITAS_DEBUG=1
